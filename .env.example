# Copy this file to .env and fill in real values
# NEVER commit .env with secrets to version control

# ── Database ──────────────────────────────────────────────────────────────────
# Local (Docker Compose)
DATABASE_URL="postgresql://souplesse:souplesse_dev@localhost:5432/souplesse_db"
# Prisma Accelerate (production — obtainable from https://console.prisma.io)
# DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-32-char-random-secret"
JWT_REFRESH_SECRET="change-me-to-another-32-char-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Kkiapay ───────────────────────────────────────────────────────────────────
KKIAPAY_API_KEY=""
KKIAPAY_SECRET_KEY=""
KKIAPAY_WEBHOOK_SECRET=""

# ── Direct DB URL (for migrations when using Prisma Accelerate) ───────────────
DIRECT_DATABASE_URL="postgresql://souplesse:souplesse_dev@localhost:5432/souplesse_db"

# ── App ───────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_NAME="Souplesse Fitness"
NUXT_PUBLIC_API_BASE="/api"
NODE_ENV="development"
PORT=3000

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM="Souplesse Fitness <onboarding@resend.dev>"

# ── App public URL (used in email verification links) ─────────────────────────
APP_URL="https://your-production-domain.com"
