# Copy this file to .env and fill in real values
# NEVER commit .env with secrets to version control

# ── Database ──────────────────────────────────────────────────────────────────
# Local (Docker Compose)
DATABASE_URL="postgresql://souplesse:souplesse_dev@localhost:5432/souplesse_db"
# Prisma Accelerate (production — obtainable from https://console.prisma.io)
# DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-32-char-random-secret"
JWT_REFRESH_SECRET="change-me-to-another-32-char-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Kkiapay (existing integration) ────────────────────────────────────────────
KKIAPAY_SECRET_KEY=""
KKIAPAY_WEBHOOK_SECRET=""

# ── Stripe (gym management integration) ───────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── App ───────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_NAME="Souplesse Fitness"
NUXT_PUBLIC_API_BASE="/api"
NODE_ENV="development"
PORT=3000
