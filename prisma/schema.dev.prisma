generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String
  priceSingle  Int
  priceCouple  Int?
  validityDays Int
  maxReports   Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BusinessHours {
  id                 String    @id @default(uuid())
  dayOfWeek          DayOfWeek @unique
  openTime           String
  closeTime          String
  isHolidayOverride  Boolean   @default(false)
}

model GymSettings {
  id            String   @id @default(uuid())
  name          String
  slogan        String?
  primaryColor  String?
  secondaryColor String?
  currency      String
  address       String?
  phone         String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PaymentOrder {
  id               String   @id @default(uuid())
  userId           String
  subscriptionPlanId String
  amount           Int
  currency         String
  status           String   @default("pending")
  kkiapayOrderToken String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  transactions     Transaction[]
}

model Transaction {
  id             String   @id @default(uuid())
  paymentOrderId String
  paymentId      String   @unique
  eventType      String
  status         String
  amount         Int
  currency       String
  rawPayload     Json
  createdAt      DateTime @default(now())

  paymentOrder   PaymentOrder @relation(fields: [paymentOrderId], references: [id])
}
