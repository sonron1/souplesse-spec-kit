generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum UserRole {
  CLIENT
  COACH
  ADMIN
}

enum SubscriptionType {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
}

enum ProgramType {
  CARDIO
  FULL_BODY
  ABDO
  UPPER_BODY
  LOWER_BODY
}

enum PlanType {
  MONTHLY
  QUARTERLY
  ANNUAL
  COUPLE_MONTHLY
  COUPLE_QUARTERLY
  COUPLE_ANNUAL
}

enum AssignmentStatus {
  PENDING    // awaiting client response
  ACCEPTED   // client accepted the coach
  REJECTED   // client refused the coach
}

enum Gender {
  MALE
  FEMALE
}

// ---------------------------------------------------------------------------
// Core User Model
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(CLIENT)
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Extended profile fields (v3)
  firstName    String?
  lastName     String?
  phone        String?   @unique
  gender       Gender?
  birthDay     Int?      // 1–31
  birthMonth   Int?      // 1–12
  avatarUrl    String?

  // Security fields (T0217 account lockout, T0218 email verification)
  loginAttempts          Int       @default(0)
  lockedUntil            DateTime?
  emailVerified          Boolean   @default(false)
  emailVerificationToken String?   @unique

  // Session token (v3 — single session, multi-device revocation)
  sessionToken          String?   @unique
  sessionTokenIssuedAt  DateTime?

  subscriptions Subscription[]
  payments      Payment[]
  bookings      Booking[]
  coachSessions  Session[]   @relation("CoachSessions")
  coachPrograms  Program[]   @relation("CoachPrograms")
  clientPrograms Program[]   @relation("ClientPrograms")
  coachAssignments  CoachClientAssignment[] @relation("CoachAssignments")
  clientAssignments CoachClientAssignment[] @relation("ClientAssignments")
  notifications     Notification[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  @@index([email])
}

// ---------------------------------------------------------------------------
// Gym Settings & Plans
// ---------------------------------------------------------------------------

model GymSettings {
  id             String   @id @default(uuid())
  name           String
  slogan         String?
  primaryColor   String?
  secondaryColor String?
  currency       String
  address        String?
  phone          String?
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BusinessHours {
  id                String    @id @default(uuid())
  dayOfWeek         DayOfWeek @unique
  openTime          String
  closeTime         String
  isHolidayOverride Boolean   @default(false)
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String   @unique
  planType     PlanType
  priceSingle  Int
  priceCouple  Int?
  validityDays Int
  maxReports   Int
  maxPauses    Int      @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

// ---------------------------------------------------------------------------
// Subscriptions & Payments (US1)
// ---------------------------------------------------------------------------

model Subscription {
  id                 String             @id @default(uuid())
  userId             String
  subscriptionPlanId String?
  type               SubscriptionType   @default(MONTHLY)
  status             SubscriptionStatus @default(PENDING)
  activationDate     DateTime?
  startsAt           DateTime?
  expiresAt          DateTime?
  maxReports         Int?
  partnerUserId      String?
  isActive           Boolean            @default(false)

  // Pause / report fields (v3 — Bloc J)
  pauseCount   Int       @default(0)
  pausedAt     DateTime?
  pausedUntil  DateTime?

  // Expiration reminder (v3 — Bloc I)
  reminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  subscriptionPlan SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  payments         Payment[]

  @@index([userId])
}

model Payment {
  id                   String        @id @default(uuid())
  userId               String
  subscriptionId       String?
  amount               Int           // XOF integer per FR-012
  currency             String        @default("XOF")
  provider             String        @default("kkiapay")
  kkiapayTransactionId String?       @unique
  status               PaymentStatus @default(PENDING)
  rawPayload           Json?         // raw provider response for audit/reconciliation (FR-007)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

// Legacy Kkiapay models kept for backward-compat
model PaymentOrder {
  id                  String   @id @default(uuid())
  userId              String
  subscriptionPlanId  String
  partnerUserId       String?  // FR-016: second user for couple/duo plans
  amount              Int
  currency            String
  status              String   @default("pending")
  kkiapayOrderToken   String?  @unique
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  transactions Transaction[]
}

model Transaction {
  id             String   @id @default(uuid())
  paymentOrderId String
  paymentId      String   @unique
  eventType      String
  status         String
  amount         Int
  currency       String
  rawPayload     Json
  createdAt      DateTime @default(now())

  paymentOrder PaymentOrder @relation(fields: [paymentOrderId], references: [id])
}

// ---------------------------------------------------------------------------
// Sessions & Bookings (US2)
// ---------------------------------------------------------------------------

model Session {
  id        String   @id @default(uuid())
  coachId   String
  dateTime  DateTime
  duration  Int      // minutes
  capacity  Int
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach    User      @relation("CoachSessions", fields: [coachId], references: [id])
  bookings Booking[]

  @@index([coachId])
  @@index([dateTime])
}

model Booking {
  id        String        @id @default(uuid())
  userId    String
  sessionId String
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@unique([userId, sessionId])
  @@index([userId])
  @@index([sessionId])
}

// ---------------------------------------------------------------------------
// Programs (US3)
// ---------------------------------------------------------------------------

model Program {
  id        String      @id @default(uuid())
  clientId  String      @unique  // one program per client
  coachId   String
  type      ProgramType @default(FULL_BODY)
  content   Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  client User @relation("ClientPrograms", fields: [clientId], references: [id])
  coach  User @relation("CoachPrograms", fields: [coachId], references: [id])

  @@index([coachId])
}

// ---------------------------------------------------------------------------
// Coach-Client Assignment (US3)
// ---------------------------------------------------------------------------

model CoachClientAssignment {
  id          String           @id @default(uuid())
  coachId     String
  clientId    String           @unique // one active coach per client
  status      AssignmentStatus @default(PENDING)
  requestedBy String?          // 'admin' | 'client'
  assignedAt  DateTime         @default(now())
  respondedAt DateTime?        // when client accepted or refused

  coach  User @relation("CoachAssignments", fields: [coachId], references: [id])
  client User @relation("ClientAssignments", fields: [clientId], references: [id])

  @@index([coachId])
  @@index([clientId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Notifications (v2)
// ---------------------------------------------------------------------------

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String    // e.g. ASSIGNMENT, SUBSCRIPTION_EXPIRING
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, readAt])
}

// ---------------------------------------------------------------------------
// Messaging (v2)
// ---------------------------------------------------------------------------

model Message {
  id          String    @id @default(uuid())
  senderId    String
  recipientId String
  coachId     String    // coach in a coach↔client or admin↔coach thread
  clientId    String?   // null = admin↔coach direct thread
  body        String
  readAt      DateTime?
  editedAt    DateTime? // v3 — message editing (Bloc P)
  createdAt   DateTime  @default(now())

  sender    User @relation("SentMessages",     fields: [senderId],    references: [id])
  recipient User @relation("ReceivedMessages", fields: [recipientId], references: [id])

  @@index([coachId, createdAt])
  @@index([coachId, clientId, createdAt])
  @@index([recipientId, readAt])
}

// ---------------------------------------------------------------------------
// System Logs (v2)
// ---------------------------------------------------------------------------

model SystemLog {
  id        String   @id @default(uuid())
  level     String   // info | warn | error
  action    String   // e.g. USER_LOGIN, BOOKING_CREATED
  userId    String?  // actor (null = anonymous / system)
  target    String?  // affected resource id (optional)
  message   String
  meta      Json?    // arbitrary extra fields
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([userId])
}
