generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum UserRole {
  CLIENT
  COACH
  ADMIN
}

enum SubscriptionType {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
}

enum ProgramType {
  GAIN
  LOSS
}

enum PlanType {
  MONTHLY
  QUARTERLY
  ANNUAL
  COUPLE_MONTHLY
  COUPLE_QUARTERLY
  COUPLE_ANNUAL
}

// ---------------------------------------------------------------------------
// Core User Model
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(CLIENT)
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  subscriptions Subscription[]
  payments      Payment[]
  bookings      Booking[]
  coachSessions  Session[]   @relation("CoachSessions")
  coachPrograms  Program[]   @relation("CoachPrograms")
  clientPrograms Program[]   @relation("ClientPrograms")
  coachAssignments  CoachClientAssignment[] @relation("CoachAssignments")
  clientAssignments CoachClientAssignment[] @relation("ClientAssignments")

  @@index([email])
}

// ---------------------------------------------------------------------------
// Gym Settings & Plans
// ---------------------------------------------------------------------------

model GymSettings {
  id             String   @id @default(uuid())
  name           String
  slogan         String?
  primaryColor   String?
  secondaryColor String?
  currency       String
  address        String?
  phone          String?
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BusinessHours {
  id                String    @id @default(uuid())
  dayOfWeek         DayOfWeek @unique
  openTime          String
  closeTime         String
  isHolidayOverride Boolean   @default(false)
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String   @unique
  planType     PlanType
  priceSingle  Int
  priceCouple  Int?
  validityDays Int
  maxReports   Int
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

// ---------------------------------------------------------------------------
// Subscriptions & Payments (US1)
// ---------------------------------------------------------------------------

model Subscription {
  id                 String             @id @default(uuid())
  userId             String
  subscriptionPlanId String?
  type               SubscriptionType   @default(MONTHLY)
  status             SubscriptionStatus @default(PENDING)
  activationDate     DateTime?
  startsAt           DateTime?
  expiresAt          DateTime?
  maxReports         Int?
  partnerUserId      String?
  isActive           Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  subscriptionPlan SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  payments         Payment[]

  @@index([userId])
}

model Payment {
  id                   String        @id @default(uuid())
  userId               String
  subscriptionId       String?
  amount               Int           // XOF integer per FR-012
  currency             String        @default("XOF")
  provider             String        @default("kkiapay")
  kkiapayTransactionId String?       @unique
  status               PaymentStatus @default(PENDING)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

// Legacy Kkiapay models kept for backward-compat
model PaymentOrder {
  id                  String   @id @default(uuid())
  userId              String
  subscriptionPlanId  String
  amount              Int
  currency            String
  status              String   @default("pending")
  kkiapayOrderToken   String?  @unique
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  transactions Transaction[]
}

model Transaction {
  id             String   @id @default(uuid())
  paymentOrderId String
  paymentId      String   @unique
  eventType      String
  status         String
  amount         Int
  currency       String
  rawPayload     Json
  createdAt      DateTime @default(now())

  paymentOrder PaymentOrder @relation(fields: [paymentOrderId], references: [id])
}

// ---------------------------------------------------------------------------
// Sessions & Bookings (US2)
// ---------------------------------------------------------------------------

model Session {
  id        String   @id @default(uuid())
  coachId   String
  dateTime  DateTime
  duration  Int      // minutes
  capacity  Int
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach    User      @relation("CoachSessions", fields: [coachId], references: [id])
  bookings Booking[]

  @@index([coachId])
  @@index([dateTime])
}

model Booking {
  id        String        @id @default(uuid())
  userId    String
  sessionId String
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@unique([userId, sessionId])
  @@index([userId])
  @@index([sessionId])
}

// ---------------------------------------------------------------------------
// Programs (US3)
// ---------------------------------------------------------------------------

model Program {
  id        String      @id @default(uuid())
  clientId  String
  coachId   String
  type      ProgramType @default(GAIN)
  content   Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  client User @relation("ClientPrograms", fields: [clientId], references: [id])
  coach  User @relation("CoachPrograms", fields: [coachId], references: [id])

  @@index([clientId])
  @@index([coachId])
}

// ---------------------------------------------------------------------------
// Coach-Client Assignment (US3)
// ---------------------------------------------------------------------------

model CoachClientAssignment {
  id         String   @id @default(uuid())
  coachId    String
  clientId   String
  assignedAt DateTime @default(now())

  coach  User @relation("CoachAssignments", fields: [coachId], references: [id])
  client User @relation("ClientAssignments", fields: [clientId], references: [id])

  @@unique([coachId, clientId])
  @@index([coachId])
  @@index([clientId])
}
