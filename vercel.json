{
  "framework": "nuxtjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": {
    "NITRO_PRESET": "vercel"
  },
  "crons": [
    {
      "path": "/api/cron/expire-subscriptions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 8 * * *"
    }
  ]
}
